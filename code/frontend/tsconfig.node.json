{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node",
  "compilerOptions": {
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "noEmit": true
  },
  "include": ["vite.config.js"]
}
